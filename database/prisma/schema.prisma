generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  birthDate DateTime?
  createdAt DateTime @default(now())
}

model Caregiver {
  id        String   @id @default(cuid())
  name      String
  patientId String
  createdAt DateTime @default(now())
}
